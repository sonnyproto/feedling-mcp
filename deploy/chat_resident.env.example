# Copy to ~/feedling-chat-resident.env and fill in real values.
# chmod 600 ~/feedling-chat-resident.env
# Do NOT commit the real env file to git.

# -------- Feedling connection --------
FEEDLING_API_URL=http://127.0.0.1:5001
FEEDLING_API_KEY=<your_api_key>

# -------- Agent backend mode --------
# Choose the entry your runtime can actually execute from this service.
# Hermes/OpenClaw normally use cli unless you have explicitly enabled the
# Hermes API server.
AGENT_MODE=cli

# -------- HTTP mode (AGENT_MODE=http) --------
# simple: POST {"message": "..."} and expect {"response": "..."} back.
# openai: POST OpenAI-compatible chat completions and preserve Hermes
#         conversation state through X-Hermes-Session-Id / X-Hermes-Session-Key.
AGENT_HTTP_PROTOCOL=simple
AGENT_HTTP_URL=http://127.0.0.1:8080/chat
AGENT_HTTP_TOKEN=
# JSON field in the response that contains the reply text (default: response)
AGENT_HTTP_FIELD=response
# Hermes API server example:
#   AGENT_HTTP_PROTOCOL=openai
#   AGENT_HTTP_URL=http://127.0.0.1:8642/v1/chat/completions
#   AGENT_HTTP_MODEL=hermes-agent
#   AGENT_HTTP_SESSION_KEY=                # optional; defaults to feedling:{user_id}

# -------- CLI mode (AGENT_MODE=cli) --------
# {message} is replaced with the user's message text at runtime.
#
# IMPORTANT: prefer valid JSON stdout with a final-answer field such as
# {"reply":"...","session_id":"..."}. Plain text is supported only as a
# fallback; terminal UI, debug footers, and decorative separators can leak.
# See tools/README.md § "Agent backend modes" for per-agent configuration notes.
#
# Hermes/OpenClaw CLI example. The consumer stores the first session_id and
# injects --resume <session_id> on later turns. Do not use --continue here:
# it means "latest local session" and can attach Feedling to the wrong chat.
# Set HERMES_HOME to the same home/profile your real running resident agent uses.
# Prefer reading it from the actual service environment, for example:
#   systemctl --user show -p MainPID --value hermes-gateway
#   tr '\0' '\n' < /proc/<MainPID>/environ | grep '^HERMES_HOME='
# Do not guess from profile folder names; some gateway installs use
# /home/openclaw/.hermes while others use /home/openclaw/.hermes/profiles/daily.
# Do not wrap {message} in a persona prompt; call the real agent entry directly.
#   AGENT_CLI_PATH=/home/openclaw/.local/bin:/home/openclaw/.hermes/hermes-agent/venv/bin
#   HERMES_HOME=/home/openclaw/.hermes/profiles/daily
#   AGENT_CLI_CMD=hermes chat -Q --source tool --max-turns 60 -q "{message}"
#
# Claude Code CLI example. The consumer reads session_id from JSON output and
# injects --resume <session_id> on later turns. Do not use --continue here.
#   AGENT_CLI_PATH=/home/openclaw/.npm-global/bin:/home/openclaw/.local/bin
#   AGENT_CLI_CMD=claude --print --output-format json "{message}"
#
# Generic example:
#   AGENT_CLI_CMD=mycli ask {message}
AGENT_CLI_PATH=
HERMES_HOME=
AGENT_CLI_CMD=hermes chat -Q --source tool --max-turns 60 -q "{message}"

# -------- Decrypt source (at least one MUST be set for v1 encrypted backends) --------
#
# ⚠️  WARNING: Without FEEDLING_ENCLAVE_URL, the consumer
#     cannot read any user messages — /v1/chat/poll returns content="" for all
#     v1 encrypted messages. The service will appear to run but will never reply.
#
# Option A — Direct enclave decrypt proxy (recommended, lowest latency):
#   Direct enclave decrypt endpoint (e.g. https://127.0.0.1:5003).
FEEDLING_ENCLAVE_URL=
# Override the API key for MCP calls (defaults to FEEDLING_API_KEY if blank).

# -------- Operational settings --------
CHECKPOINT_FILE=/tmp/feedling_chat_checkpoint.json
# Optional: persist upstream agent session id for stable memory across restarts.
# {user_id} is replaced at runtime (prevents cross-user context mixing).
AGENT_SESSION_FILE=/tmp/feedling_agent_session_{user_id}.txt
FALLBACK_REPLY=（Agent 暂时无法响应，请稍后再试）
FALLBACK_COOLDOWN=60
SEND_FALLBACK_ON_AGENT_ERROR=false
POLL_TIMEOUT=30
LOG_LEVEL=INFO
# Reply writes refresh /v1/users/whoami before encrypting. If the refresh sees a
# transient TLS/network failure, the consumer retries briefly, then falls back to
# already cached keys when available so one blip does not drop a user reply.
WHOAMI_REFRESH_RETRIES=3
WHOAMI_REFRESH_RETRY_DELAY_SEC=0.5

# -------- Proactive V2 resident runtime --------
# The consumer owns the resident proactive loop: heartbeat tick, hidden job poll,
# and minute-level scheduled_wake fire. Keep scheduled fire shorter than the
# heartbeat tick so agent-created timers trigger near their requested minute.
PROACTIVE_POLL_ENABLED=true
PROACTIVE_POLL_TIMEOUT=1
PROACTIVE_TICK_ENABLED=true
PROACTIVE_TICK_INTERVAL_SEC=300
PROACTIVE_TICK_BROADCAST_OFF_INTERVAL_SEC=1800
PROACTIVE_TICK_START_DELAY_SEC=15
PROACTIVE_SCHEDULED_FIRE_ENABLED=true
PROACTIVE_SCHEDULED_FIRE_INTERVAL_SEC=60
PROACTIVE_SCHEDULED_FIRE_START_DELAY_SEC=5

# -------- Image message handling --------
# When the user sends an image-only message (content_type=image, content=""),
# the consumer decrypts image_b64 and passes image context to the agent:
# - OpenAI-compatible HTTP: image_url content block
# - simple HTTP: images[] array
# - CLI: local file path, optionally via {image_path}/{image_paths}
IMAGE_TEMP_DIR=/tmp/feedling_chat_images
IMAGE_PLACEHOLDER=[The user sent an image in IO Chat. Inspect the attached/local image before replying. If your current runtime cannot open the image, say plainly that this connector has not enabled image vision yet.]
