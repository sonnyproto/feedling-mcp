# Copy to /home/ubuntu/feedling.env and fill in real values
# Do NOT commit the real feedling.env to git

# -------- deployment mode --------
# Backend is always multi-tenant. Every request must carry a valid X-API-Key
# issued by POST /v1/users/register. There is no shared-key mode.

# -------- storage + networking --------
# All per-user data now lives in PostgreSQL (see backend/db.py), NOT in files.
# DATABASE_URL is REQUIRED — the backend fails to boot without it. For an
# external/managed Postgres it MUST include sslmode=require (TLS). The data at
# rest is E2E-encrypted ciphertext, but the DB still sees plaintext metadata
# (user ids, timestamps, app names, visibility) — use a trusted/managed PG.
DATABASE_URL=postgresql://feedling:CHANGE_ME@db.example.internal:5432/feedling?sslmode=require

# FEEDLING_DATA_DIR is still used for non-user-data files in the data volume
# (e.g. the APNs .p8 push key), not for user persistence anymore.
FEEDLING_DATA_DIR=/home/ubuntu/feedling-data
FEEDLING_PUBLIC_BASE_URL=https://api.feedling.app
FEEDLING_FLASK_URL=http://127.0.0.1:5001
FEEDLING_MCP_PORT=5002
FEEDLING_MCP_TRANSPORT=sse

# -------- hosted proactive (Model API users) --------
# Set to 0 to disable the hosted tick scheduler entirely.
FEEDLING_HOSTED_TICK_ENABLED=1
# Minimum interval (seconds) between heartbeat wakes for each hosted user.
# Default 1800 = 30 minutes. Set lower for testing; set higher to reduce load.
FEEDLING_HOSTED_TICK_INTERVAL_SEC=1800

# -------- APNs (copy from existing setup) --------
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=/home/ubuntu/feedling-data/apns.p8
BUNDLE_ID=
