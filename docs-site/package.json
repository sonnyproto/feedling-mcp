{
  "name": "docs-site",
  "version": "0.0.5",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "openapi:generate": "python3 ../tools/export_public_openapi.py --output openapi/public.json",
    "start": "serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.4",
    "fumadocs-mdx": "15.1.1",
    "fumadocs-openapi": "^11.2.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.17",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
