{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feedling.app/schemas/agent-e2e/run-result-v1.json",
  "title": "Feedling API-Key Deployed-Runtime Qualification Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suite_id",
    "run_id",
    "started_at",
    "finished_at",
    "target",
    "overall_status",
    "profiles_expected",
    "profiles_completed",
    "orchestration",
    "profiles",
    "summary",
    "artifacts",
    "redaction"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "suite_id": {
      "const": "feedling-api-key-p0"
    },
    "run_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "overall_status": {
      "$ref": "#/$defs/status"
    },
    "profiles_expected": {
      "const": 8
    },
    "profiles_completed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "orchestration": {
      "$ref": "#/$defs/orchestration"
    },
    "profiles": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/profileResult"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "redaction": {
      "$ref": "#/$defs/redaction"
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "PRODUCT_FAIL",
        "BLOCKED_CREDENTIAL",
        "BLOCKED_EVIDENCE",
        "BLOCKED_DEPLOYMENT",
        "AGENT_ERROR",
        "SECURITY_FAIL"
      ]
    },
    "safeLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/+-]{0,159}$"
    },
    "nullableSafeLabel": {
      "oneOf": [
        {
          "$ref": "#/$defs/safeLabel"
        },
        {
          "type": "null"
        }
      ]
    },
    "modelLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u200B-\\u200F\\u2028-\\u202E\\u2060-\\u206F\\uFEFF|`]+$"
    },
    "nullableModelLabel": {
      "oneOf": [
        {
          "$ref": "#/$defs/modelLabel"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableSha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$"
    },
    "nullableNonnegativeNumber": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "stageLatency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "routing",
        "queue",
        "provider",
        "persistence",
        "delivery"
      ],
      "properties": {
        "routing": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "queue": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "provider": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "persistence": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "delivery": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment",
        "base_url",
        "expected_deployment_sha",
        "observed_backend_sha",
        "observed_worker_sha",
        "expected_runtime"
      ],
      "properties": {
        "environment": {
          "const": "test"
        },
        "base_url": {
          "const": "https://test-api.feedling.app"
        },
        "expected_deployment_sha": {
          "type": "string",
          "minLength": 7,
          "maxLength": 64,
          "pattern": "^[0-9a-fA-F]+$"
        },
        "observed_backend_sha": {
          "$ref": "#/$defs/nullableSha"
        },
        "observed_worker_sha": {
          "$ref": "#/$defs/nullableSha"
        },
        "expected_runtime": {
          "type": "string",
          "enum": [
            "deployed_current",
            "hosted_resident"
          ]
        }
      }
    },
    "orchestration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supervisor_count",
        "max_configured_profile_concurrency",
        "max_observed_profile_concurrency",
        "profile_worker_assignments"
      ],
      "properties": {
        "supervisor_count": {
          "const": 1
        },
        "max_configured_profile_concurrency": {
          "const": 3
        },
        "max_observed_profile_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "profile_worker_assignments": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/profileWorkerAssignment"
          }
        }
      }
    },
    "profileWorkerAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "worker_id"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "enum": [
            "official-deepseek",
            "official-anthropic",
            "official-openai",
            "official-gemini",
            "openrouter-claude",
            "openrouter-openai",
            "openrouter-glm",
            "relay-kongbeiqie"
          ]
        },
        "worker_id": {
          "$ref": "#/$defs/safeLabel"
        }
      }
    },
    "profileResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "route_family",
        "model_family",
        "provider",
        "model",
        "reasoning_effort",
        "user_id",
        "expected_runtime",
        "observed_runtime",
        "observed_runtime_version",
        "status",
        "scenarios",
        "turns",
        "latency",
        "reasoning",
        "trace",
        "cleanup",
        "diagnostic_codes",
        "redaction"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "enum": [
            "official-deepseek",
            "official-anthropic",
            "official-openai",
            "official-gemini",
            "openrouter-claude",
            "openrouter-openai",
            "openrouter-glm",
            "relay-kongbeiqie"
          ]
        },
        "route_family": {
          "type": "string",
          "enum": [
            "official",
            "openrouter",
            "relay"
          ]
        },
        "model_family": {
          "type": "string",
          "enum": [
            "deepseek",
            "claude",
            "openai",
            "gemini",
            "glm"
          ]
        },
        "provider": {
          "type": "string",
          "enum": [
            "deepseek",
            "anthropic",
            "openai",
            "gemini",
            "openrouter",
            "openai_compatible"
          ]
        },
        "model": {
          "$ref": "#/$defs/modelLabel"
        },
        "reasoning_effort": {
          "const": "medium"
        },
        "user_id": {
          "$ref": "#/$defs/nullableSafeLabel"
        },
        "expected_runtime": {
          "type": "string",
          "enum": [
            "deployed_current",
            "hosted_resident"
          ]
        },
        "observed_runtime": {
          "$ref": "#/$defs/nullableSafeLabel"
        },
        "observed_runtime_version": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "scenarios": {
          "type": "array",
          "minItems": 13,
          "maxItems": 13,
          "items": {
            "$ref": "#/$defs/scenarioResult"
          }
        },
        "turns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/turnResult"
          }
        },
        "latency": {
          "$ref": "#/$defs/latencySummary"
        },
        "reasoning": {
          "$ref": "#/$defs/reasoningEvidence"
        },
        "trace": {
          "$ref": "#/$defs/traceEvidence"
        },
        "cleanup": {
          "$ref": "#/$defs/cleanup"
        },
        "diagnostic_codes": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/diagnosticCode"
          }
        },
        "redaction": {
          "$ref": "#/$defs/redaction"
        }
      }
    },
    "scenarioResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "status",
        "started_at",
        "finished_at",
        "attempts",
        "attempt_results",
        "assertions",
        "evidence_codes",
        "request_ids",
        "turn_ids",
        "trace_ids",
        "persona_finalizer",
        "failure"
      ],
      "properties": {
        "scenario_id": {
          "type": "string",
          "enum": [
            "P0-01",
            "P0-02",
            "P0-03",
            "P0-04",
            "P0-05",
            "P0-06",
            "P0-07",
            "P0-08",
            "P0-09",
            "P0-10",
            "P0-11",
            "P0-12",
            "P0-13"
          ]
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        },
        "attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "attempt_results": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/attemptResult"
          }
        },
        "assertions": {
          "type": "object",
          "maxProperties": 64,
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          },
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "evidence_codes": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/evidenceCode"
          }
        },
        "request_ids": {
          "$ref": "#/$defs/idList"
        },
        "turn_ids": {
          "$ref": "#/$defs/idList"
        },
        "trace_ids": {
          "$ref": "#/$defs/idList"
        },
        "persona_finalizer": {
          "oneOf": [
            {
              "$ref": "#/$defs/personaFinalizerEvidence"
            },
            {
              "type": "null"
            }
          ]
        },
        "failure": {
          "$ref": "#/$defs/failure"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            }
          },
          "then": {
            "properties": {
              "failure": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "failure": {
                "type": "object"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "scenario_id": {
                "const": "P0-06"
              }
            },
            "required": [
              "scenario_id"
            ]
          },
          "then": {
            "properties": {
              "persona_finalizer": {
                "$ref": "#/$defs/personaFinalizerEvidence"
              }
            }
          },
          "else": {
            "properties": {
              "persona_finalizer": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "attemptResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt",
        "status",
        "failure"
      ],
      "properties": {
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "failure": {
          "$ref": "#/$defs/failure"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            }
          },
          "then": {
            "properties": {
              "failure": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "failure": {
                "type": "object"
              }
            }
          }
        }
      ]
    },
    "turnResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "turn_index",
        "request_id",
        "turn_id",
        "trace_id",
        "ack_latency_ms",
        "reply_latency_ms",
        "stage_latency_ms",
        "reply_count",
        "content_assertion_passed",
        "fallback_detected",
        "duplicate_detected",
        "out_of_order_detected"
      ],
      "properties": {
        "scenario_id": {
          "type": "string",
          "pattern": "^P0-(0[1-9]|1[0-3])$"
        },
        "turn_index": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "request_id": {
          "$ref": "#/$defs/safeLabel"
        },
        "turn_id": {
          "$ref": "#/$defs/nullableSafeLabel"
        },
        "trace_id": {
          "$ref": "#/$defs/nullableSafeLabel"
        },
        "ack_latency_ms": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "reply_latency_ms": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "stage_latency_ms": {
          "$ref": "#/$defs/stageLatency"
        },
        "reply_count": {
          "type": "integer",
          "minimum": 0
        },
        "content_assertion_passed": {
          "type": "boolean"
        },
        "fallback_detected": {
          "type": "boolean"
        },
        "duplicate_detected": {
          "type": "boolean"
        },
        "out_of_order_detected": {
          "type": "boolean"
        }
      }
    },
    "latencySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_count",
        "ack_p50_ms",
        "reply_p50_ms",
        "reply_p95_ms",
        "stage_p50_ms",
        "missing_stages"
      ],
      "properties": {
        "sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "ack_p50_ms": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "reply_p50_ms": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "reply_p95_ms": {
          "$ref": "#/$defs/nullableNonnegativeNumber"
        },
        "stage_p50_ms": {
          "$ref": "#/$defs/stageLatency"
        },
        "missing_stages": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "routing",
              "queue",
              "provider",
              "persistence",
              "delivery"
            ]
          }
        }
      }
    },
    "reasoningEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected",
        "capability_enabled",
        "requested_effort",
        "configured_effort",
        "effective_effort",
        "reasoning_event_count",
        "metadata_present",
        "token_metadata_present",
        "user_visible_disclosure_present",
        "request_id",
        "turn_id",
        "trace_id",
        "kind",
        "source",
        "model",
        "reasoning_token_count",
        "disclosure_length",
        "raw_private_reasoning_stored"
      ],
      "properties": {
        "expected": {
          "type": "boolean"
        },
        "capability_enabled": {
          "type": "boolean"
        },
        "requested_effort": {
          "type": "string",
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh",
            "unsupported",
            "unknown"
          ]
        },
        "configured_effort": {
          "type": "string",
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh",
            "unsupported",
            "unknown"
          ]
        },
        "effective_effort": {
          "type": "string",
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh",
            "unsupported",
            "unknown"
          ]
        },
        "reasoning_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "metadata_present": {
          "type": "boolean"
        },
        "token_metadata_present": {
          "type": "boolean"
        },
        "user_visible_disclosure_present": {
          "type": "boolean"
        },
        "request_id": {
          "$ref": "#/$defs/safeLabel"
        },
        "turn_id": {
          "$ref": "#/$defs/safeLabel"
        },
        "trace_id": {
          "$ref": "#/$defs/safeLabel"
        },
        "kind": {
          "$ref": "#/$defs/nullableSafeLabel"
        },
        "source": {
          "$ref": "#/$defs/nullableSafeLabel"
        },
        "model": {
          "$ref": "#/$defs/nullableModelLabel"
        },
        "reasoning_token_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "disclosure_length": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "raw_private_reasoning_stored": {
          "type": "boolean"
        }
      }
    },
    "personaFinalizerEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "evidence_sha256",
        "request_id",
        "job_id",
        "semantic_judgment_bound",
        "finalizer_ok",
        "private_evidence_deleted",
        "privacy_violation_count"
      ],
      "properties": {
        "fixture_id": {
          "const": "persona-import-v1"
        },
        "evidence_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "request_id": {
          "$ref": "#/$defs/safeLabel"
        },
        "job_id": {
          "$ref": "#/$defs/safeLabel"
        },
        "semantic_judgment_bound": {
          "const": true
        },
        "finalizer_ok": {
          "const": true
        },
        "private_evidence_deleted": {
          "const": true
        },
        "privacy_violation_count": {
          "const": 0
        }
      }
    },
    "traceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "deploy_enabled",
        "correlated_event_count",
        "observed_event_types",
        "missing_required_event_types",
        "raw_trace_stored"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "deploy_enabled": {
          "type": "boolean"
        },
        "correlated_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "observed_event_types": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 5,
          "items": {
            "type": "string",
            "enum": [
              "routing",
              "queue",
              "provider",
              "persistence",
              "delivery"
            ]
          }
        },
        "missing_required_event_types": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "routing",
              "queue",
              "provider",
              "persistence",
              "delivery"
            ]
          }
        },
        "raw_trace_stored": {
          "const": false
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempted",
        "provider_config_deleted",
        "account_reset",
        "old_credential_rejected",
        "status"
      ],
      "properties": {
        "attempted": {
          "type": "boolean"
        },
        "provider_config_deleted": {
          "type": "boolean"
        },
        "account_reset": {
          "type": "boolean"
        },
        "old_credential_rejected": {
          "type": "boolean"
        },
        "status": {
          "$ref": "#/$defs/status"
        }
      }
    },
    "failure": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "category",
            "stage_code",
            "failure_code",
            "reproducible"
          ],
          "properties": {
            "category": {
              "$ref": "#/$defs/status"
            },
            "stage_code": {
              "$ref": "#/$defs/failureStageCode"
            },
            "failure_code": {
              "$ref": "#/$defs/failureCode"
            },
            "reproducible": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "idList": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/safeLabel"
      }
    },
    "evidenceCode": {
      "type": "string",
      "enum": [
        "AGENT_ENVIRONMENT_SANITIZED",
        "AGENT_IDENTITY_CONFIRMED",
        "ASSERTIONS_CONFIRMED",
        "ASYNC_ACK_RECEIVED",
        "BACKEND_SHA_MATCHED",
        "CHAT_LOOP_VERIFIED",
        "CLEANUP_CONFIRMED",
        "CONTRACT_INPUTS_READABLE",
        "CREDENTIAL_OMITTED",
        "DEPLOYED_ENDPOINT_REACHABLE",
        "DISCLOSURE_PRESENT",
        "DRIVER_ENABLED",
        "EXACT_REPLY_CORRELATED",
        "HOSTED_CHAT_NOT_STARTED",
        "INVALID_KEY_NOT_ECHOED",
        "INVALID_KEY_REJECTED",
        "LATENCY_ATTRIBUTED",
        "MEMORY_RECALL_CONFIRMED",
        "MODEL_ROUTE_CONFIRMED",
        "NO_ORPHAN_TURN",
