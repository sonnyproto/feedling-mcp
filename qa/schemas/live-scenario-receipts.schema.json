{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feedling.app/schemas/live-scenario-receipts.schema.json",
  "title": "Parent-owned live scenario receipt set",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "run_id", "profile_id", "receipts"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "live_scenario_receipt_set"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]{1,128}$"},
    "profile_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]{1,128}$"},
    "receipts": {
      "type": "array",
      "minItems": 9,
      "maxItems": 18,
      "items": {"$ref": "#/$defs/receipt"}
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9._:/-]{1,256}$"},
    "latency": {"type": ["number", "null"], "minimum": 0},
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turn_index", "request_id", "turn_id", "trace_id", "ack_latency_ms", "reply_latency_ms", "reply_count", "content_assertion_passed", "fallback_detected", "duplicate_detected", "out_of_order_detected"],
      "properties": {
        "turn_index": {"type": "integer", "minimum": 1, "maximum": 10},
        "request_id": {"$ref": "#/$defs/id"},
        "turn_id": {"$ref": "#/$defs/id"},
        "trace_id": {"$ref": "#/$defs/id"},
        "ack_latency_ms": {"$ref": "#/$defs/latency"},
        "reply_latency_ms": {"$ref": "#/$defs/latency"},
        "reply_count": {"type": "integer", "minimum": 0},
        "content_assertion_passed": {"type": ["boolean", "null"]},
        "fallback_detected": {"type": "boolean"},
        "duplicate_detected": {"type": "boolean"},
        "out_of_order_detected": {"type": "boolean"}
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "run_id", "profile_id", "scenario_id", "attempt", "nonce", "started_at", "finished_at", "status", "failure_code", "assertions", "semantic_assertions", "request_ids", "turn_ids", "trace_ids", "turns", "private_facts_sha256", "raw_content_stored"],
      "properties": {
        "schema_version": {"const": 1},
        "kind": {"const": "live_scenario_probe"},
        "run_id": {"type": "string"},
        "profile_id": {"type": "string"},
        "scenario_id": {"enum": ["P0-02", "P0-03", "P0-04", "P0-05", "P0-07", "P0-08", "P0-09", "P0-10", "P0-11"]},
        "attempt": {"type": "integer", "minimum": 1, "maximum": 2},
        "nonce": {"$ref": "#/$defs/id"},
        "started_at": {"type": "string", "format": "date-time"},
        "finished_at": {"type": "string", "format": "date-time"},
        "status": {"enum": ["PASS", "AGENT_ERROR", "PRODUCT_FAIL", "BLOCKED_CREDENTIAL", "BLOCKED_EVIDENCE", "BLOCKED_DEPLOYMENT", "SECURITY_FAIL"]},
        "failure_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{0,63}$"},
        "assertions": {"type": "object", "additionalProperties": {"type": "boolean"}},
        "semantic_assertions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "request_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "turn_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "trace_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "turns": {"type": "array", "maxItems": 10, "items": {"$ref": "#/$defs/turn"}},
        "private_facts_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "raw_content_stored": {"const": false}
      }
    }
  }
}
